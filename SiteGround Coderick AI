@charset "utf-8";

.sg-cursor-text * { cursor: text !important; }

.sg-cursor-pointer * { cursor: pointer !important; }

[contenteditable="true"] { outline: none !important; }

[data-visual-edit-overlay="hover"]::before { content: attr(data-visual-edit-label); position: absolute; left: 0px; background: rgb(67, 67, 240); border-radius: 4px; color: white; padding: 2px 4px; font-family: Inter; font-size: 12px; font-style: normal; font-weight: 400; line-height: 18px; }

[data-visual-edit-overlay="hover"][data-visual-edit-label-position="top"]::before { bottom: calc(100% + 4px); }

[data-visual-edit-overlay="hover"][data-visual-edit-label-position="bottom"]::before { top: calc(100% + 4px); }

[data-visual-edit-overlay="hover"][data-visual-edit-dimensions]::after { content: attr(data-visual-edit-dimensions); position: absolute; top: 4px; right: 4px; background: rgb(67, 67, 240); border-radius: 4px; color: white; padding: 2px 4px; font-family: Inter; font-size: 12px; font-style: normal; font-weight: 400; line-height: 18px; }

.sg-icon-loader-circular { animation: 2s linear 0s infinite normal none running sg-preview-rotate; transform-origin: center center; }

.sg-icon-loader-path { stroke-dasharray: 1, 200; stroke-dashoffset: 0; animation: 1.5s ease-in-out 0s infinite normal none running sg-preview-dash, 6s ease-in-out 0s infinite normal none running sg-preview-color; stroke-linecap: round; }

@keyframes sg-preview-rotate { 
  100% { transform: rotate(360deg); }
}

@keyframes sg-preview-dash { 
  0% { stroke-dasharray: 1, 200; stroke-dashoffset: 0; }
  50% { stroke-dasharray: 89, 200; stroke-dashoffset: -35px; }
  100% { stroke-dasharray: 89, 200; stroke-dashoffset: -124px; }
}

@keyframes sg-preview-color { 
  100%, 0% { stroke: rgb(255, 112, 97); }
  40% { stroke: rgb(33, 171, 97); }
  66% { stroke: rgb(67, 67, 240); }
  80%, 90% { stroke: rgb(255, 112, 97); }
}
