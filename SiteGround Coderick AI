.sg-file-drop-zone { position: relative; width: 100%; }

.sg-file-drop-zone--active { position: relative; outline: 2px dashed var(--color-primary); outline-offset: -2px; border-radius: var(--radius-medium); }

.sg-file-drop-zone__overlay { position: absolute; top: 0px; left: 0px; width: 100%; height: 100%; background-color: rgba(var(--color-primary-rgb),.1); display: flex; align-items: center; justify-content: center; border-radius: var(--radius-medium); }

.sg-file-drop-zone__message { background-color: transparent; }

.sg-file-drop-zone__message span { color: var(--color-primary); font-weight: 500; }

.voice-recording-visualizer { padding: 0 var(--space-medium); width: 100%; height: 32px; display: block; }

.sg-ai-chat { height: 100%; }

.sg-ai-chat__input-wrapper { transition: opacity 0.2s, visibility 0.2s; }

.sg-ai-chat__input-wrapper.hidden { opacity: 0; visibility: hidden; height: 0px; overflow: hidden; pointer-events: none; }

.sg-chat-conversation { width: 100%; display: flex; flex-direction: column; gap: var(--space-medium); }

.sg-chat-conversation li { word-break: normal; }

.sg-chat-conversation figure { display: block; padding: 20px; text-align: center; background-image: linear-gradient(45deg, rgb(234, 228, 219) 25%, transparent 25%), linear-gradient(-45deg, rgb(234, 228, 219) 25%, transparent 25%), linear-gradient(45deg, transparent 75%, rgb(234, 228, 219) 75%), linear-gradient(-45deg, transparent 75%, rgb(234, 228, 219) 75%); background-size: 4px 4px; background-position: -2px -2px, 0px 2px, 0px 0px, 2px 0px; }

.sg-chat-conversation figure img { border: 1px solid var(--border-color-outer); border-radius: var(--radius-default); margin: 0px auto; max-width: 100%; height: auto; box-sizing: content-box; }

.sg-chat-conversation hr { height: 4px; padding: 0px; margin: 16px 0px; border: 0px; }

.sg-chat-conversation .sg-blockquote { padding: var(--space-small) var(--space-medium); margin: var(--space-small) 0; border-left: 4px solid var(--border-color-outer); background-color: var(--background-color-subtle); border-radius: var(--radius-default); }

.sg-chat-conversation .sg-table { width: 100%; border-collapse: collapse; margin: var(--space-small) 0; }

.sg-chat-conversation .sg-table th, .sg-chat-conversation .sg-table td { padding: var(--space-x-small) var(--space-small); border: 1px solid var(--border-color-outer); text-align: left; }

.sg-chat-conversation .sg-table th { background-color: var(--background-color-subtle); font-weight: 700; }

.sg-chat-conversation .sg-table tr:nth-child(2n) { background-color: var(--background-color-subtle); }

.sg-status-card { position: relative; width: 100%; background: var(--color-primary-contrast); border-radius: var(--radius-medium); border: 1px solid var(--color-border-main); min-height: 66px; }

.sg-status-card--last-in-chain { border-color: var(--color-border-action-focused); }

.sg-status-card__label { position: absolute; top: 0px; left: 50%; transform: translate(-50%, -50%); }

.sg-status-card__loader { position: absolute; right: 32px; top: 50%; transform: translateY(-50%); }

.sg-status-card .sg-status-card--info-wrapper { width: calc(100% - 80px); }

.sg-status-card .sg-status-card--title { text-overflow: ellipsis; white-space: nowrap; overflow: hidden; flex: 1 1 0%; }

.sg-status-card .sg-icon-button { margin-left: 0px; }

.sg-status-card .preview-icon { cursor: default; }

.sg-status-card .preview-icon .sg-button-base__overlay { background-color: var(--button-base-overlay-background-hovered); }

.sg-status-card .preview-icon .sg-ripple { display: none; }

.sg-has-error-notice { max-width: 100%; }

.sg-code-block { width: 100%; border-radius: var(--radius-medium); border: 1px solid var(--color-border-action-focused); margin: var(--spacing-small) 0; }

.sg-code-block--collapsed { border: 1px solid var(--border-color-focus); }

.sg-code-block--collapsed .sg-code-block__header { border-radius: var(--radius-medium); }

.sg-code-block--expanded .sg-code-block__header { border-bottom: 1px solid var(--color-border-action-focused); }

.sg-code-block--expanded { border: 1px solid var(--color-border-action-focused); }

.sg-code-block__header { border-radius: var(--radius-medium) var(--radius-medium) 0 0; }

.sg-code-block__content { position: relative; }

.sg-code-block__content--collapsed { max-height: 0px; opacity: 0; overflow: hidden; transition: opacity 0.2s ease-out, max-height 0.2s ease-out; pointer-events: none; }

.sg-code-block__content--expanded { opacity: 1; transition: opacity 0.2s ease-in; }

.sg-code-block__content pre { margin: 0px; padding: 20px; overflow: auto; max-height: 500px; border-radius: 0 0 var(--radius-medium) var(--radius-medium); }

.sg-code-block__content code { display: block; background: transparent; color: var(--color-typography-primary); font-family: "Fira Code", Consolas, Monaco, "Andale Mono", "Ubuntu Mono", monospace; font-size: 14px; line-height: 1.2; white-space: pre; overflow-wrap: normal; word-break: normal; tab-size: 2; }

.animated-loader { position: relative; overflow: hidden; width: 100%; }

@keyframes dropIn { 
  0% { opacity: 0; }
  100% { opacity: 0.9; }
}

.shining-text { position: relative; display: inline-block; }

.shining-text::after { content: attr(data-text); position: absolute; top: 0px; left: 0px; width: 100%; height: 100%; color: transparent; background-image: linear-gradient(to right,transparent 0%,transparent 40%,var(--color-background-primary) 50%,transparent 60%,transparent 100%); background-size: 200%; background-clip: text; animation: 3s linear 0s infinite normal none running shine; }

@keyframes shine { 
  0% { background-position: 200% center; }
  100% { background-position: -200% center; }
}

.sg-ai-chat-message--bot { width: 100%; overflow-wrap: break-word; word-break: break-word; }

.sg-ai-chat-message--bot-content { max-width: 100%; }

.sg-theme-hcb .sg-ai-chat-message--bot, .sg-theme-hcl .sg-ai-chat-message--bot { background-color: transparent; border: 1px solid var(--border-color-outer); border-radius: var(--radius-large); }

.sg-ai-chat-message { max-width: 100%; padding: var(--space-2x-small); overflow: visible; }

.sg-ai-chat-message--user { padding: var(--space-small) var(--space-medium); background-color: var(--color-background-tertiary); border-radius: var(--radius-x-large); max-width: 80%; }

.sg-ai-chat-message__link { word-break: break-word; }

.sg-image-preview__in-message { width: 106px; height: 106px; padding: unset !important; }

